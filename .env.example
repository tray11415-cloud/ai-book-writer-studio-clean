# Writing route: Interactive Writing and Rewrite use NALANG plus Local LoRA.
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_MODEL=nalang-xl-0826-10k
OPENAI_API_KEY=replace-with-your-nalang-api-key
UPSTREAM_OPENAI_BASE_URL=https://www.gpt4novel.com/api/xiaoshuoai/ext/v1

# Analysis route: Style DNA, Story Chronicle, and Chapter Craft Analysis use Grok.
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3
XAI_API_KEY=replace-with-your-xai-api-key

# Planning route: Plot Ideation uses Grok + NALANG + Local LoRA together.
UI_LORA_BASE_URL=http://127.0.0.1:8010/v1
UI_LORA_MODEL=qwen3-4b-novel-lora

# Cross-response repetition guard (repetition_guard.py). All optional; defaults shown.
# See README "Cross-Response Repetition Guard" for details.
# Master on/off switch (set to 0/false/off/no to disable the guard entirely).
BOOK_WRITER_REPETITION_GUARD=1
# Overlap ratio (0..1) above which a continuation is regenerated.
BOOK_WRITER_REPETITION_THRESHOLD=0.30
# Max regeneration retries when overlap is too high.
BOOK_WRITER_REPETITION_MAX_RETRIES=1
# CJK char n-gram size used to measure overlap with the prior story.
BOOK_WRITER_REPETITION_NGRAM=8
# CJK char n-gram size used to mine recurring 套路 phrases.
BOOK_WRITER_REPETITION_PHRASE_NGRAM=10
# Minimum recurrences before a phrase counts as overused.
BOOK_WRITER_REPETITION_MIN_COUNT=3
# How many overused phrases to feed back as an avoid-list.
BOOK_WRITER_REPETITION_TOP_K=14

# Web chat UI (web_app.py): max tokens per assistant reply.
BOOK_WRITER_CHAT_MAX_TOKENS=4000

# Writing length (Interactive Writing tab).
# Max Tokens slider ceiling. NOTE: a single API call is still capped by the model's
# own output limit (e.g. nalang-*-16k ~16k); reach very long output by continuing
# repeatedly. Default slider value stays moderate so each gen doesn't request the max.
BOOK_WRITER_MAX_TOKENS=100000
BOOK_WRITER_DEFAULT_TOKENS=24000
# Max output tokens for the continuation director's-manual prompt (tab 12 step 3).
# Larger = longer/more detailed plan, but it feeds the WRITING model's context, so
# keep it well under that model's window.
BOOK_WRITER_CONTINUATION_PLAN_MAX_TOKENS=16000
# Each beat is expanded in its own parallel LLM call (so beats are never merged into
# ranges or truncated). Worker count = AI_BOOK_MAX_WORKERS. This caps total beats.
BOOK_WRITER_CONTINUATION_MAX_BEATS=60

# Cross-reply continuity (Interactive Writing). Before each generation, summarize the
# current story into a compact "story state" (location/characters/just-happened/open
# tension/last beat) and inject it as a hard continuity anchor so each reply picks up
# exactly where the last left off. Costs one small extra LLM call per generation;
# set to 0/false to disable.
BOOK_WRITER_CONTINUITY_STATE=1
BOOK_WRITER_CONTINUITY_STATE_TOKENS=500
BOOK_WRITER_CONTINUITY_STATE_SOURCE_CHARS=6000
